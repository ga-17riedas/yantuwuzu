.container {
  position: relative;
  padding: 20px;
}

.background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.ranking-container {
  background-color: rgba(255, 255, 255, 0.9);
  padding: 20px;
  border-radius: 10px;
  margin-bottom: 50px;
}

.ranking-header, .ranking-item {
  display: flex;
  font-size: 10px;
  justify-content: space-between;
  padding: 10px 0;
  margin-bottom: 5px;
  border-bottom: 1px solid #eee;
}

.ranking-header {
  font-weight: bold;
  border-bottom: 2px solid #ccc;
}

.ranking-index {
  position: relative;
  display: flex;
  align-items: center;
}

.ranking-index text {
  position: relative;
  z-index: 1;
}

.user-info {
  display: flex;
  align-items: center;
}

.top-rank {
  color: transparent; /* 将排名1，2，3的索引字体颜色改为透明色 */
}

.medal {
  position: absolute;
  top: 0;
  left: -10px;
  width: 25px;
  height: 25px;
  z-index: 0;
}

.avatar {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  margin-right: 5px;
}

.my-ranking {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 10px 20px;
  border-radius: 20px;
  text-align: center;
  white-space: nowrap; /* 文字不换行 */
  overflow: hidden; /* 隐藏溢出部分 */
  text-overflow: ellipsis; 
}
