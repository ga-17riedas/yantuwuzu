.container {
  padding: 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background-color: #f5f5f5;
  height: 100%;
}

.white-container {
  background-color: white;
  border-radius: 10px;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
  padding: 20px;
}

.header {
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
  font-size: 20px;
  color: black;
}

.score, .time {
  margin-bottom: 20px;
  font-size: 18px;
  color: black;
}

.questions {
  margin-bottom: 20px;
  font-size: 18px;
  color: black;
}

.question {
  margin-bottom: 20px;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 20px;
}

.question text {
  display: block;
  margin-bottom: 5px;
}

.question button {
  padding: 5px 10px;
  background-color: #1aad19;
  color: white;
  border: none;
  border-radius: 5px;
  font-size: 14px;
}

.rank-button {
  padding: 10px;
  background-color: #225fd1;
  color: white;
  border: none;
  border-radius: 5px;
  font-size: 18px;
  text-align: center;
  margin-top: 20px;
}

.correct {
  color: green;
}

.incorrect {
  color: red;
}
